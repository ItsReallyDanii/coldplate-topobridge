# coldplate-topobridge gitignore

# Bridge run artifacts (tracked as .gitkeep placeholder only)
artifacts/run_*/
artifacts/*.npz
artifacts/*.npy
artifacts/*.jsonl
artifacts/*.json

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/
*.egg

# Virtual environments
.venv/
venv/
.env/

# Pytest
.pytest_cache/
.coverage
htmlcov/

# Editor
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Temporary test outputs
/tmp/
